═══════════════════════════════════════════════════════════ */

@import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Mono:wght@300;400;500&display=swap');

:root {
  --bg:        #040a06;
  --surface:   #080f0a;
  --surface2:  #0d1710;
  --border:    rgba(0, 255, 120, 0.08);
  --border2:   rgba(0, 255, 120, 0.16);
  --em:        #00ff78;   /* electric mint — primary accent */
  --em2:       #00e5ff;   /* cyan secondary */
  --em3:       #7fff00;   /* chartreuse tertiary */
  --warn:      #ff6b35;   /* orange alert */
  --purple:    #bf5fff;
  --text:      #d4f0dc;
  --muted:     #4a6650;
  --muted2:    #7a9e82;
  --card-r:    12px;
  --nav-h:     60px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'DM Sans', system-ui, sans-serif;
  font-size: 15px;
  line-height: 1.6;
  overflow-x: hidden;
}

/* Circuit-board grid background */
body::after {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(0,255,120,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,255,120,0.025) 1px, transparent 1px);
  background-size: 48px 48px;
  pointer-events: none;
  z-index: 0;
}

/* ── STICKY NAV ─────────────────────────────────────────── */
.ag-nav {
  position: sticky;
  top: 0;
  z-index: 200;
  background: rgba(4, 10, 6, 0.9);
  backdrop-filter: blur(24px) saturate(160%);
  border-bottom: 1px solid var(--border2);
  height: var(--nav-h);
  display: flex;
  align-items: center;
  padding: 0 2rem;
  gap: 1rem;
}

.ag-nav-brand {
  font-family: 'DM Mono', monospace;
  font-size: 0.78rem;
  letter-spacing: 0.18em;
  color: var(--em);
  white-space: nowrap;
  flex-shrink: 0;
  text-shadow: 0 0 14px rgba(0,255,120,0.5);
}
.ag-nav-brand span { color: var(--muted); }

.search-wrap {
  flex: 1;
  max-width: 360px;
  position: relative;
}
.search-wrap svg {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  width: 15px;
  height: 15px;
  color: var(--muted2);
  pointer-events: none;
}
#searchInput {
  width: 100%;
  background: var(--surface2);
  border: 1px solid var(--border2);
  border-radius: 6px;
  padding: 0.48rem 0.75rem 0.48rem 2.4rem;
  font-family: 'DM Mono', monospace;
  font-size: 0.78rem;
  color: var(--text);
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
  letter-spacing: 0.03em;
}
#searchInput::placeholder { color: var(--muted); }
#searchInput:focus {
  border-color: rgba(0,255,120,0.5);
  box-shadow: 0 0 0 3px rgba(0,255,120,0.07);
}

/* Category pills */
.cat-filters {
  display: flex;
  gap: 0.35rem;
  overflow-x: auto;
  scrollbar-width: none;
  flex: 1;
}
.cat-filters::-webkit-scrollbar { display: none; }

.cat-pill {
  white-space: nowrap;
  font-family: 'DM Mono', monospace;
  font-size: 0.68rem;
  letter-spacing: 0.07em;
  padding: 0.28rem 0.75rem;
  border-radius: 4px;
  border: 1px solid var(--border2);
  background: transparent;
  color: var(--muted2);
  cursor: pointer;
  transition: all 0.15s;
  flex-shrink: 0;
}
.cat-pill:hover, .cat-pill.active {
  background: var(--em);
  border-color: var(--em);
  color: #000;
  box-shadow: 0 0 12px rgba(0,255,120,0.3);
}

/* ── HERO ───────────────────────────────────────────────── */
.ag-hero {
  position: relative;
  text-align: center;
  padding: 5rem 2rem 3.5rem;
  overflow: hidden;
  z-index: 1;
}

/* Animated scanner line */
.ag-hero::before {
  content: '';
  position: absolute;
  left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--em), transparent);
  animation: scanner 4s ease-in-out infinite;
  opacity: 0.4;
}
@keyframes scanner {
  0%   { top: 0%;   opacity: 0; }
  10%  { opacity: 0.5; }
  90%  { opacity: 0.5; }
  100% { top: 100%; opacity: 0; }
}

.ag-hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: 'DM Mono', monospace;
  font-size: 0.68rem;
  letter-spacing: 0.2em;
  color: var(--em);
  border: 1px solid rgba(0,255,120,0.3);
  padding: 0.28rem 1rem;
  border-radius: 3px;
  margin-bottom: 1.75rem;
  background: rgba(0,255,120,0.04);
}
.ag-hero-badge::before {
  content: '▶';
  font-size: 0.5rem;
  animation: blink 1.2s step-end infinite;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

.ag-hero h1 {
  font-size: clamp(2.8rem, 6vw, 5.5rem);
  font-weight: 600;
  line-height: 1.0;
  letter-spacing: -0.04em;
  margin-bottom: 1.25rem;
  color: var(--text);
}
.ag-hero h1 em {
  font-style: normal;
  color: var(--em);
  text-shadow: 0 0 40px rgba(0,255,120,0.4);
}

.ag-hero p {
  font-size: 1rem;
  color: var(--muted2);
  max-width: 56ch;
  margin: 0 auto 2.5rem;
  font-weight: 300;
  line-height: 1.7;
}

.ag-stats {
  display: inline-flex;
  gap: 0;
  border: 1px solid var(--border2);
  border-radius: 6px;
  overflow: hidden;
}
.ag-stat {
  padding: 0.75rem 2rem;
  border-right: 1px solid var(--border2);
  text-align: center;
}
.ag-stat:last-child { border-right: none; }
.ag-stat-val {
  font-family: 'DM Mono', monospace;
  font-size: 1.5rem;
  font-weight: 500;
  color: var(--em);
  text-shadow: 0 0 20px rgba(0,255,120,0.3);
  line-height: 1;
}
.ag-stat-label {
  font-family: 'DM Mono', monospace;
  font-size: 0.6rem;
  letter-spacing: 0.15em;
  color: var(--muted);
  margin-top: 0.3rem;
}

/* ── MAIN ───────────────────────────────────────────────── */
.ag-main {
  position: relative;
  z-index: 1;
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 2rem 6rem;
}

.no-results {
  display: none;
  text-align: center;
  padding: 4rem 2rem;
  color: var(--muted);
  font-family: 'DM Mono', monospace;
  font-size: 0.8rem;
  letter-spacing: 0.1em;
}

/* ── CATEGORY SECTION ───────────────────────────────────── */
.cat-section {
  margin-bottom: 3.5rem;
  opacity: 0;
  transform: translateY(18px);
  animation: sectionReveal 0.5s ease forwards;
}
.cat-section.hidden { display: none; }

@keyframes sectionReveal {
  to { opacity: 1; transform: translateY(0); }
}

.cat-section-head {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  margin-bottom: 1.25rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--border2);
}

.cat-icon-wrap {
  width: 42px; height: 42px;
  border-radius: 8px;
  border: 1px solid var(--border2);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.1rem;
  flex-shrink: 0;
  background: var(--surface2);
}

.cat-section-info { flex: 1; }

.cat-section-title {
  font-size: 1.1rem;
  font-weight: 600;
  letter-spacing: -0.025em;
  color: var(--text);
  margin-bottom: 0.2rem;
}

.cat-section-desc {
  font-size: 0.8rem;
  color: var(--muted2);
  max-width: 72ch;
  line-height: 1.5;
}

.cat-count {
  font-family: 'DM Mono', monospace;
  font-size: 0.65rem;
  color: var(--em);
  border: 1px solid rgba(0,255,120,0.25);
  padding: 0.2rem 0.6rem;
  border-radius: 3px;
  flex-shrink: 0;
  letter-spacing: 0.08em;
  background: rgba(0,255,120,0.04);
}

/* ── AGENT GRID ─────────────────────────────────────────── */
.agent-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
  gap: 1rem;
}

/* ── AGENT CARD ─────────────────────────────────────────── */
.agent-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--card-r);
  padding: 1.2rem;
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
  position: relative;
  overflow: hidden;
  transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
}

/* Top accent line */
.agent-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--em), transparent);
  opacity: 0;
  transition: opacity 0.2s;
}
.agent-card:hover::before { opacity: 0.6; }
.agent-card:hover {
  transform: translateY(-3px);
  border-color: rgba(0,255,120,0.2);
  box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 0 0 1px rgba(0,255,120,0.06);
}

/* Capability bar in corner */
.agent-card-head {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
}

.agent-logo {
  width: 40px; height: 40px;
  border-radius: 8px;
  background: var(--surface2);
  border: 1px solid var(--border2);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.1rem;
  flex-shrink: 0;
}

.agent-meta { flex: 1; min-width: 0; }

.agent-name {
  font-weight: 600;
  font-size: 0.9rem;
  color: var(--text);
  letter-spacing: -0.01em;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.agent-type {
  font-family: 'DM Mono', monospace;
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  color: var(--em);
  margin-top: 0.15rem;
  opacity: 0.8;
}

/* Pricing badge */
.agent-badge {
  font-family: 'DM Mono', monospace;
  font-size: 0.6rem;
  letter-spacing: 0.08em;
  padding: 0.15rem 0.5rem;
  border-radius: 3px;
  border: 1px solid;
  flex-shrink: 0;
}
.badge-free    { color: #00ff78; border-color: rgba(0,255,120,0.3); background: rgba(0,255,120,0.06); }
.badge-freemium{ color: #00e5ff; border-color: rgba(0,229,255,0.3); background: rgba(0,229,255,0.06); }
.badge-paid    { color: #ff6b35; border-color: rgba(255,107,53,0.3); background: rgba(255,107,53,0.06); }
.badge-open    { color: #7fff00; border-color: rgba(127,255,0,0.3);  background: rgba(127,255,0,0.06); }

.agent-desc {
  font-size: 0.78rem;
  color: var(--muted2);
  line-height: 1.6;
  flex: 1;
}

/* Capabilities chips */
.agent-caps {
  display: flex;
  flex-wrap: wrap;
  gap: 0.3rem;
}
.cap-chip {
  font-family: 'DM Mono', monospace;
  font-size: 0.6rem;
  letter-spacing: 0.05em;
  padding: 0.15rem 0.5rem;
  border-radius: 3px;
  background: rgba(0,255,120,0.05);
  border: 1px solid rgba(0,255,120,0.12);
  color: var(--muted2);
}

.agent-card-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
  margin-top: auto;
  padding-top: 0.5rem;
  border-top: 1px solid var(--border);
}

.agent-model {
  font-family: 'DM Mono', monospace;
  font-size: 0.62rem;
  color: var(--muted);
  letter-spacing: 0.05em;
}

.visit-btn {
  font-family: 'DM Mono', monospace;
  font-size: 0.68rem;
  letter-spacing: 0.08em;
  padding: 0.42rem 1rem;
  border-radius: 4px;
  background: transparent;
  color: var(--em);
  border: 1px solid rgba(0,255,120,0.35);
  cursor: pointer;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  white-space: nowrap;
  flex-shrink: 0;
  transition: background 0.15s, box-shadow 0.15s, color 0.15s;
}
.visit-btn:hover {
  background: var(--em);
  color: #000;
  box-shadow: 0 0 16px rgba(0,255,120,0.35);
}
.visit-btn svg { width: 10px; height: 10px; }

/* ── FEATURED CARD ──────────────────────────────────────── */
.agent-card.featured {
  border-color: rgba(0,255,120,0.2);
  background: linear-gradient(135deg, var(--surface) 0%, rgba(0,255,120,0.03) 100%);
}
.agent-card.featured::after {
  content: 'FEATURED';
  position: absolute;
  top: 0.75rem; right: 0.75rem;
  font-family: 'DM Mono', monospace;
  font-size: 0.55rem;
  letter-spacing: 0.12em;
  color: var(--em);
  border: 1px solid rgba(0,255,120,0.3);
  padding: 0.1rem 0.4rem;
  border-radius: 2px;
  background: rgba(0,255,120,0.06);
}

/* ── SEARCH HIDDEN ──────────────────────────────────────── */
.agent-card.search-hidden { display: none; }

/* ── FOOTER ─────────────────────────────────────────────── */
.ag-footer {
  position: relative;
  z-index: 1;
  border-top: 1px solid var(--border2);
  padding: 2rem;
  text-align: center;
  font-family: 'DM Mono', monospace;
  font-size: 0.7rem;
  color: var(--muted);
  letter-spacing: 0.08em;
}

/* ── RESPONSIVE ─────────────────────────────────────────── */
@media (max-width: 900px) {
  .ag-nav { gap: 0.5rem; padding: 0 1rem; }
  .ag-nav-brand { display: none; }
}
@media (max-width: 640px) {
  .agent-grid { grid-template-columns: 1fr 1fr; }
  .ag-hero { padding: 3rem 1rem 2.5rem; }
  .ag-stats { flex-direction: column; border: none; gap: 0.5rem; }
  .ag-stat { border-right: none; border: 1px solid var(--border2); border-radius: 4px; }
  .cat-filters { display: none; }
  .ag-main { padding: 0 1rem 4rem; }
}
@media (max-width: 420px) {
  .agent-grid { grid-template-columns: 1fr; }
}
</style>

