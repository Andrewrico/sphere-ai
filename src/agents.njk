</footer>

<script>
(function () {
  'use strict';

  /* stagger section animations */
  document.querySelectorAll('.cat-section').forEach((sec, i) => {
    sec.style.animationDelay = (i * 0.06) + 's';
  });

  /* category filter */
  const pills = document.querySelectorAll('.cat-pill');
  const sections = document.querySelectorAll('.cat-section');

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      pills.forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      const cat = pill.dataset.cat;
      sections.forEach(sec => {
        sec.classList.toggle('hidden', cat !== 'all' && sec.dataset.category !== cat);
      });
      updateCount();
    });
  });

  /* search */
  const searchInput = document.getElementById('searchInput');
  const noResults   = document.getElementById('noResults');
  let timer;

  searchInput.addEventListener('input', () => {
    clearTimeout(timer);
    timer = setTimeout(runSearch, 160);
  });

  function runSearch() {
    const q = searchInput.value.trim().toLowerCase();
    const cards = document.querySelectorAll('.agent-card');

    if (q) {
      pills.forEach(p => p.classList.remove('active'));
      sections.forEach(s => s.classList.remove('hidden'));
    }

    cards.forEach(card => {
      const hay = (card.dataset.name || '') + ' ' + card.textContent.toLowerCase();
      card.classList.toggle('search-hidden', !!(q && !hay.includes(q)));
    });

    sections.forEach(sec => {
      const vis = sec.querySelectorAll('.agent-card:not(.search-hidden)').length;
      sec.classList.toggle('hidden', vis === 0);
    });

    const any = [...sections].some(s => !s.classList.contains('hidden'));
    noResults.style.display = any ? 'none' : 'block';
    updateCount();
  }

  /* scroll-reveal */
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.style.opacity = '1';
          e.target.style.transform = 'translateY(0)';
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.04, rootMargin: '0px 0px -30px 0px' });

    document.querySelectorAll('.agent-card').forEach(card => {
      card.style.opacity = '0';
      card.style.transform = 'translateY(10px)';
      card.style.transition = 'opacity 0.35s ease, transform 0.35s ease';
      io.observe(card);
    });
  }

  /* counts */
  function updateCount() {
    const n = document.querySelectorAll('.agent-card:not(.search-hidden)').length;
    const el = document.getElementById('totalAgents');
    if (el) el.textContent = n + '+';
  }

  const total = document.querySelectorAll('.agent-card').length;
  const fc = document.getElementById('footerCount');
  if (fc) fc.textContent = total + '+';
  const hc = document.getElementById('totalAgents');
  if (hc) hc.textContent = total + '+';
}());
</script>
