<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title or "SPHERE — AI Interface" }}</title>
  <meta name="description" content="{{ description or 'SPHERE — Next-generation AI interface and AI tools directory.' }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg:      #020408;
      --surface: #060d16;
      --border:  rgba(0, 210, 255, 0.12);
      --accent:  #00d2ff;
      --accent2: #7b2fff;
      --accent3: #ff2fa0;
      --text:    #c8e8f5;
      --muted:   #3a5568;
      --glow:    rgba(0, 210, 255, 0.35);
      --glow2:   rgba(123, 47, 255, 0.3);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: 'JetBrains Mono', monospace;
      overflow-x: hidden;
    }

    /* Starfield */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        radial-gradient(1px 1px at 10% 15%, rgba(255,255,255,0.6) 0%, transparent 100%),
        radial-gradient(1px 1px at 30% 60%, rgba(0,210,255,0.5) 0%, transparent 100%),
        radial-gradient(1px 1px at 50% 25%, rgba(255,255,255,0.4) 0%, transparent 100%),
        radial-gradient(1px 1px at 70% 80%, rgba(123,47,255,0.5) 0%, transparent 100%),
        radial-gradient(1px 1px at 85% 40%, rgba(255,255,255,0.4) 0%, transparent 100%),
        radial-gradient(1px 1px at 20% 85%, rgba(0,210,255,0.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 60% 55%, rgba(255,255,255,0.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 92% 10%, rgba(255,47,160,0.4) 0%, transparent 100%),
        radial-gradient(1px 1px at 45% 90%, rgba(255,255,255,0.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 75% 20%, rgba(0,210,255,0.4) 0%, transparent 100%);
      pointer-events: none;
      z-index: 0;
    }

    main { position: relative; z-index: 1; }

    /* Global page nav (only shown on homepage) */
    .site-nav-link {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      z-index: 999;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      padding: 0.6rem 1.2rem;
      background: rgba(6, 13, 22, 0.9);
      border: 1px solid var(--border);
      border-radius: 999px;
      color: var(--accent);
      text-decoration: none;
      backdrop-filter: blur(12px);
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .site-nav-link:hover {
      border-color: var(--accent);
      box-shadow: 0 0 20px rgba(0, 210, 255, 0.2);
    }
    .site-nav-link::before {
      content: '';
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 6px var(--accent);
    }
  </style>
</head>
<body>
  <main>{{ content | safe }}</main>
  <!-- Floating nav pill — links between pages -->
  <a href="{{ '/directory/' if page.url == '/' else '/' }}" class="site-nav-link">
    {{ 'AI Directory' if page.url == '/' else 'Back to SPHERE' }}
  </a>
</body>
</html>
