<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title or "SPHERE — AI Interface" }}</title>
  <meta name="description" content="{{ description or 'SPHERE — Next-generation AI interface and AI tools directory.' }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg:      #020408;
      --surface: #060d16;
      --border:  rgba(0, 210, 255, 0.12);
      --accent:  #00d2ff;
      --accent2: #7b2fff;
      --accent3: #ff2fa0;
      --text:    #c8e8f5;
      --muted:   #3a5568;
      --glow:    rgba(0, 210, 255, 0.35);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; background: var(--bg); color: var(--text); font-family: 'JetBrains Mono', monospace; overflow-x: hidden; }
    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image:
        radial-gradient(1px 1px at 10% 15%, rgba(255,255,255,0.6) 0%, transparent 100%),
        radial-gradient(1px 1px at 30% 60%, rgba(0,210,255,0.5) 0%, transparent 100%),
        radial-gradient(1px 1px at 50% 25%, rgba(255,255,255,0.4) 0%, transparent 100%),
        radial-gradient(1px 1px at 70% 80%, rgba(123,47,255,0.5) 0%, transparent 100%),
        radial-gradient(1px 1px at 85% 40%, rgba(255,255,255,0.4) 0%, transparent 100%),
        radial-gradient(1px 1px at 20% 85%, rgba(0,210,255,0.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 60% 55%, rgba(255,255,255,0.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 92% 10%, rgba(255,47,160,0.4) 0%, transparent 100%),
        radial-gradient(1px 1px at 45% 90%, rgba(255,255,255,0.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 75% 20%, rgba(0,210,255,0.4) 0%, transparent 100%);
      pointer-events: none; z-index: 0;
    }
    main { position: relative; z-index: 1; }

    /* ── Floating nav dock ── */
    .site-dock {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      z-index: 999;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      align-items: flex-end;
    }
    .site-dock a {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.1em;
      padding: 0.5rem 1rem;
      background: rgba(6, 13, 22, 0.92);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 999px;
      color: #6b7280;
      text-decoration: none;
      backdrop-filter: blur(16px);
      transition: border-color 0.2s, color 0.2s, box-shadow 0.2s;
      white-space: nowrap;
    }
    .site-dock a:hover { color: #e8e8f0; border-color: rgba(255,255,255,0.2); }
    .site-dock a.active { color: var(--accent); border-color: rgba(0,210,255,0.3); box-shadow: 0 0 16px rgba(0,210,255,0.1); }
    .site-dock a.active-agents { color: #00ff78; border-color: rgba(0,255,120,0.3); box-shadow: 0 0 16px rgba(0,255,120,0.1); }
    .site-dock a::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
  </style>
</head>
<body>
  <main>{{ content | safe }}</main>

  <nav class="site-dock" aria-label="Site navigation">
    <a href="/" {% if page.url == "/" %}class="active"{% endif %}>SPHERE</a>
    <a href="/directory/" {% if page.url == "/directory/" %}class="active"{% endif %}>AI TOOLS</a>
    <a href="/agents/" {% if page.url == "/agents/" %}class="active-agents"{% endif %}>AI AGENTS</a>
  </nav>
</body>
</html>
